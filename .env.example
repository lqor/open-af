# Copy to `.env` for local-only use. Never commit real credentials.
# Salesforce auth for local scripts/tests
SF_USERNAME=your-salesforce-username
SF_PASSWORD=your-salesforce-password
SF_LOGIN_URL=https://login.salesforce.com
SF_APP_URL=https://your-instance.salesforce.com/lightning/n/Open_AF_Chat

# LLM provider keys (use org/platform secret storage in production)
ANTHROPIC_API_KEY=REPLACE_ME_ANTHROPIC_API_KEY
OPENAI_API_KEY=REPLACE_ME_OPENAI_API_KEY
